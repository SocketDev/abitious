{
  "private": true,
  "name": "abitious-workspace",
  "description": "Workspace root for the abitious npm distribution (@abitious/cli + per-triple platform packages). The crates are the Cargo workspace; this drives codegen, typecheck, and the JS tests.",
  "license": "MIT",
  "scripts": {
    "gen": "node scripts/gen-packages.mts",
    "gen:check": "node scripts/gen-packages.mts --check",
    "test": "node --test 'npm/cli/test/**/*.test.mjs'",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "22.13.0",
    "typescript": "5.9.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
