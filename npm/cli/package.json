{
  "name": "@abitious/cli",
  "version": "0.1.0",
  "description": "Ship Node.js native addons as compressed, self-loading hybrid .node files. The `abi` build CLI + the platform loader that resolves the prebuilt stub and host producer for your platform.",
  "keywords": [
    "addon",
    "cli",
    "compression",
    "decmpfs",
    "napi"
  ],
  "license": "MIT",
  "repository": "https://github.com/SocketDev/abitious",
  "bin": {
    "abi": "bin.cjs"
  },
  "files": [
    "bin.cjs",
    "index.cjs",
    "index.d.cts",
    "loader.cjs",
    "targets.generated.json"
  ],
  "type": "commonjs",
  "main": "index.cjs",
  "types": "index.d.cts",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "optionalDependencies": {
    "@abitious/darwin-arm64": "0.1.0",
    "@abitious/darwin-x64": "0.1.0",
    "@abitious/linux-x64-gnu": "0.1.0",
    "@abitious/linux-arm64-gnu": "0.1.0",
    "@abitious/linux-x64-musl": "0.1.0",
    "@abitious/linux-arm64-musl": "0.1.0",
    "@abitious/win32-x64-msvc": "0.1.0",
    "@abitious/win32-arm64-msvc": "0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
